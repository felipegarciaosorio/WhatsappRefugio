# ── IA ──────────────────────────────────────────────────────────────────────────
# Gemini (gratis): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=obtener_en_aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash

# Groq (fallback gratis): https://console.groq.com/keys
GROQ_API_KEY=obtener_en_console.groq.com
GROQ_MODEL=llama3-8b-8192

# ── WhatsApp vía Whapi.cloud ─────────────────────────────────────────────────────
# https://panel.whapi.cloud → crear canal → copiar token
WHAPI_TOKEN=token_de_whapi_cloud

# ── Pago ─────────────────────────────────────────────────────────────────────────
NEQUI_NUMERO=57300XXXXXXX
BANCO_CUENTA=CUENTA_BANCOLOMBIA
NUMERO_WA=57300XXXXXXX

# ── Panel admin ──────────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=contraseña_segura

# ── Configuración ────────────────────────────────────────────────────────────────
PORT=3000
TZ=America/Bogota
